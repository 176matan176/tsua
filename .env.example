# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/tsua"

# Redis
REDIS_URL="redis://localhost:6379"

# Supabase (optional - use for managed Postgres + Auth)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Stock Data APIs
POLYGON_API_KEY=""           # optional - for production real-time US data

# News
NEWS_API_KEY=""              # newsapi.org - optional

# Exchange Rate
EXCHANGE_RATE_API_KEY=""     # exchangerate-api.com - optional

# App
NODE_ENV="development"
PORT=3001
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
